# Copie para `.env` na mesma pasta (`apps/mobile`) e preencha no Supabase Dashboard:
# Project Settings → Connect → Expo (URL + anon ou publishable key).
# Não commite `.env`; apenas este arquivo com placeholders.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

{
  "expo": {
    "name": "Meubolso",
    "slug": "meubolso",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "meubolso",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#16cf70"
    },
    "ios": {
      "supportsTablet": true,
      "statusBarStyle": "auto"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#16cf70"
      },
      "softwareKeyboardLayoutMode": "resize",
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "androidStatusBar": {
        "translucent": false,
        "backgroundColor": "#000000",
        "barStyle": "light-content"
      },
      "package": "com.danielazevedocb.meubolso"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9076fada-e263-4683-8cb1-62b46bb962f7"
      }
    },
    "owner": "danielazevedocb"
  }
}
